{
  "info": {
    "name": "Real Estate CRM API",
    "description": "Complete API collection for Real Estate CRM",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@realestate.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Property Types",
      "item": [
        {
          "name": "Get All Property Types",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/property-types",
              "host": ["{{baseUrl}}"],
              "path": ["api", "property-types"]
            }
          }
        },
        {
          "name": "Create Property Type",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Apartment\",\n  \"description\": \"Multi-unit residential building\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/property-types",
              "host": ["{{baseUrl}}"],
              "path": ["api", "property-types"]
            }
          }
        },
        {
          "name": "Update Property Type",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Apartment\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/property-types/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "property-types", ":id"]
            }
          }
        },
        {
          "name": "Delete Property Type",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/property-types/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "property-types", ":id"]
            }
          }
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "Get All Leads",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/leads?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leads"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "leadType",
                  "value": "Buyer",
                  "disabled": true
                },
                {
                  "key": "city",
                  "value": "Mumbai",
                  "disabled": true
                },
                {
                  "key": "leadStatus",
                  "value": "New",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Get Lead Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/leads/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leads", "stats"]
            }
          }
        },
        {
          "name": "Create Lead",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leadType\": \"Buyer\",\n  \"fullName\": \"John Doe\",\n  \"phoneNumber\": \"9876543210\",\n  \"email\": \"john@example.com\",\n  \"city\": \"Mumbai\",\n  \"budget\": 5000000,\n  \"propertyType\": \"property_type_id\",\n  \"propertyCondition\": \"property_condition_id\",\n  \"preferredLocation\": \"Andheri West\",\n  \"leadStatus\": \"New\",\n  \"assignedTo\": \"admin_id\",\n  \"remarks\": \"Interested in 2BHK\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/leads",
              "host": ["{{baseUrl}}"],
              "path": ["api", "leads"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "token",
      "value": "your_jwt_token_here"
    }
  ]
}
